   "id": "0e50ea5a-5ac9-433e-89e5-ba26eb9b0282",
   "metadata": {},
   "outputs": [],
   "source": [
    "START\n",
    "INPUT Prices\n",
    "INPUT Quantity\n",
    "COMPUTE Total = Price * Quantity\n",
    "\n",
    "INPUT Payment\n",
    "IF Payment > Total THEN\n",
    "COMPUTE Change = Payment - Total\n",
    "PRINT Change\n",
    "PRINT Total\n",
    "\n",
    "\n",
    "ELSE IF Payment < Total THEN\n",
    "PRINT \"Insufficient payment. Kindly complete payment\"\n",
    "\n",
    "ELSE PRINT Total\n",
    "END"
   ]
  }
 ],
